# Copy this file to .env and fill in the values.
# docker compose up will pick it up automatically.

# Required: repository / project name tagged on every audit row
AUDIT_PROJECT=myorg/myrepo

# Optional: branch name — auto-detected from git if left blank
AUDIT_BRANCH=

# Optional: set to false to omit request bodies from storage
AUDIT_CAPTURE_REQUESTS=true

# Optional: comma-separated Go regexps — matches are replaced with [REDACTED]
# Example: '[A-Za-z0-9._%+\-]+@[A-Za-z0-9.\-]+\.[A-Za-z]{2,},sk-[a-zA-Z0-9]{32,}'
AUDIT_SCRUB_PATTERNS=

# Optional: route outbound LLM connections through an upstream proxy
UPSTREAM_PROXY=

# Optional: enable OpenTelemetry traces (OTLP/HTTP)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=codesteward-audit-proxy
